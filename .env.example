APP_NAME=ai-issue-checker
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_HOST_PORT=8000
APP_ENABLE_SCHEDULER=true

MONGODB_URI=mongodb://mongodb:27017/ai_issue_checker
MONGODB_DB=ai_issue_checker
MONGODB_ALIAS=default
MONGO_MOCK=false

SCHEDULER_INTERVAL_SECONDS=5
SCHEDULER_LEASE_SECONDS=180
SCHEDULER_MAX_TASK_RETRIES=3
SCHEDULER_RETRY_BACKOFF_SECONDS=30
SCHEDULER_SHUTDOWN_GRACE_SECONDS=30
FILE_CONCURRENCY=4

LLM_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_FALLBACK_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=120
LLM_API_RETRY_TIMES=2
LLM_RETRY_BACKOFF_SECONDS=1
LLM_RETRY_BACKOFF_MAX_SECONDS=8
LLM_MAX_TOOL_ROUNDS=30
LLM_FILE_TIMEOUT_SECONDS=600
LLM_MOCK_ENABLED=true

CODE_REPOSITORY_ROOT=/ShareData
REVIEW_ALLOWED_EXTENSIONS=.py,.js,.jsx,.ts,.tsx,.go,.java,.kt,.c,.h,.cpp,.hpp,.cc,.cs,.rs,.php,.rb,.swift,.scala,.sql,.yaml,.yml,.json,.toml,.ini,.md,.sh,.ps1,.html,.css,.scss,.vue
REVIEW_EXCLUDE_DIRS=.git,__pycache__,node_modules,.venv,venv,dist,build,.pytest_cache
REVIEW_TOOL_MAX_READ_LINES=500
REVIEW_TOOL_MAX_SEARCH_MATCHES=100
REVIEW_TOOL_MAX_FILE_BYTES=2097152
SOURCE_API_MAX_FILE_BYTES=5242880

EMAIL_SENDER=ci-ai-codereview@example.com
EMAIL_ADMIN_RECEIVERS=admin@example.com
EMAIL_ACCOUNT_DOMAIN=example.com
EMAIL_REPORT_BASE_URL=http://127.0.0.1:8000

# docker compose 用：宿主机 Polyspace 对应代码仓库父目录
CODE_REPOSITORY_HOST_PATH=./repositories
